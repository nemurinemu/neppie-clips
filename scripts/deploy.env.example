# Copy to scripts/deploy.env and fill in. This file is gitignored.

# SSH target: user@host, or an alias from your ssh config
SSH_HOST=you@your-vps

# ssh program used for transport. Leave as 'ssh' on Linux/macOS.
# In WSL, set to 'ssh.exe' to reuse the Windows ssh config + agent
# (Linux rsync/ssh otherwise can't see your Windows Host aliases or keys).
SSH_BIN=ssh

# Monorepo location on the server. Source is rsynced here and pm2 runs from it.
REMOTE_ROOT=/opt/neppie-clips

# Directory nginx serves the built website from (client dist lands here).
WEB_ROOT=/var/www/neppie-clips

# pm2 process names — must match deploy/ecosystem.config.cjs
PM2_API=neppie-api
PM2_FETCHER=neppie-fetcher
