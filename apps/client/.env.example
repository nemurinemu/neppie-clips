# Base path for the API. In prod nginx serves it same-origin, so leave as /api.
VITE_API_BASE="/api"

# Base path for nginx-served media (thumbnails/ and videos/ live under here).
VITE_MEDIA_BASE="/media"

# Dev only: proxy /api and /media to this origin (the API serves both in dev).
# Include the scheme, e.g. http://localhost:3200
VITE_DEV_PROXY_TARGET=
